# Supabase project credentials
# Copy this file to `.env.local` and fill in real values from
# https://supabase.com/dashboard → Project Settings → API.
# `.env.local` is gitignored — never commit real credentials.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Supabase MCP server (for Claude Code only — NOT used at runtime)
# Get a Personal Access Token from:
#   https://supabase.com/dashboard/account/tokens
# Then export both vars in your shell (~/.zshrc or per-session):
#   export SUPABASE_ACCESS_TOKEN=sbp_xxx
#   export SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
SUPABASE_PROJECT_REF=your-project-ref
